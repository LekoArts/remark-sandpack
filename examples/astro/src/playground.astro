---
import type { SandpackPredefinedTemplate, SandpackSetup } from '@codesandbox/sandpack-react'
import { SandpackClient } from './SandpackClient'

interface Props {
  files: Record<string, string>
  template?: SandpackPredefinedTemplate
  title: string
  customSetup?: SandpackSetup
}

const { files, template, customSetup } = Astro.props
---

<SandpackClient files={files} template={template} customSetup={customSetup} client:visible />
